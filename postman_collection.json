{
  "info": {
    "name": "Mini Laundry Order Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000"
    },
    {
      "key": "orderId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Create Order",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerName\": \"Aarav Sharma\",\n  \"phoneNumber\": \"9876543210\",\n  \"garments\": [\n    { \"garment\": \"Shirt\", \"quantity\": 3 },\n    { \"garment\": \"Pants\", \"quantity\": 2 }\n  ]\n}"
        },
        "url": "{{baseUrl}}/orders"
      }
    },
    {
      "name": "List Orders",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/orders"
      }
    },
    {
      "name": "Filter Orders by Status",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/orders?status=RECEIVED"
      }
    },
    {
      "name": "Search Orders",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/orders?search=aarav"
      }
    },
    {
      "name": "Update Order Status",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"PROCESSING\"\n}"
        },
        "url": "{{baseUrl}}/orders/{{orderId}}/status"
      }
    },
    {
      "name": "Dashboard",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/dashboard"
      }
    }
  ]
}
